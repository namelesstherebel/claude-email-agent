# claude-email-agent environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Deployment ──────────────────────────────────────────────────────────────
# local  = run manually on your machine
# server = run as systemd service or Docker container
DEPLOY_MODE=local

# ─── Reply Mode ──────────────────────────────────────────────────────────────
# draft = save as Gmail drafts (RECOMMENDED to start)
# send  = auto-send replies immediately
REPLY_MODE=draft

# ─── Polling ─────────────────────────────────────────────────────────────────
# How often to check for new emails (seconds)
POLL_INTERVAL_SECONDS=60

# ─── Sender Filters ──────────────────────────────────────────────────────────
# Whitelist: only reply to these senders (comma-separated, leave blank for all)
ONLY_REPLY_TO=

# Blocklist: never reply to senders matching these patterns
IGNORE_SENDERS=noreply@,no-reply@,mailer-daemon@,postmaster@

# ─── Gmail Label ─────────────────────────────────────────────────────────────
# Label applied to emails after processing (leave blank to skip)
LABEL_AFTER_REPLY=AI-Replied

# ─── Claude Model ─────────────────────────────────────────────────────────────
# claude-haiku-4-5 = fastest and cheapest (recommended)
# claude-sonnet-4-6 = higher quality, moderate cost
MODEL=claude-haiku-4-5
MAX_TOKENS=1024
