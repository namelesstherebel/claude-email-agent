# ============================================================
# Claude Email Agent -- Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The setup wizard (setup.sh) will fill most of this for you.
# NEVER commit your .env file to git.


# ---- Email Provider -------------------------------------------
# Which email provider you use. Set automatically by setup.sh.
#   gmail    = Gmail via Google OAuth2
#   outlook  = Outlook / Microsoft 365 via Microsoft Graph API
#   yahoo    = Yahoo Mail via IMAP
#   icloud   = iCloud Mail via IMAP
#   imap     = Any other IMAP/SMTP provider
EMAIL_PROVIDER=gmail


# ---- Claude (Anthropic) API -----------------------------------
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ---- Gmail Settings (EMAIL_PROVIDER=gmail only) ---------------
# These are handled automatically by Google OAuth2.
# credentials.json must be in your project folder (from Google Cloud Console).
# token.json is created automatically the first time you run the agent.
# Do NOT set these manually -- leave blank if you are not using Gmail.
#
# (No extra variables needed here -- credentials.json handles everything)


# ---- Outlook / Microsoft 365 Settings (EMAIL_PROVIDER=outlook only) --
# These come from your Azure App Registration.
# See setup.sh Step 2 for detailed instructions.
#
# Application (client) ID from Azure portal:
OUTLOOK_CLIENT_ID=
#
# Client secret value (copy immediately -- it is only shown once):
OUTLOOK_CLIENT_SECRET=
#
# Directory (tenant) ID from Azure portal.
# For personal outlook.com / hotmail.com accounts, use: consumers
# For work/school accounts, use your actual tenant ID.
OUTLOOK_TENANT_ID=


# ---- IMAP / SMTP Settings (EMAIL_PROVIDER=yahoo, icloud, or imap) ----
# Your full email address (e.g. you@yahoo.com or you@icloud.com):
EMAIL_ADDRESS=
#
# App password generated from your provider's security settings.
# NOT your regular login password -- use the special app password.
#   Yahoo:  myaccount.yahoo.com > Security > App Passwords
#   iCloud: appleid.apple.com > Sign-In and Security > App-Specific Passwords
#   Other:  check your provider's two-factor / app-password documentation
EMAIL_APP_PASSWORD=
#
# IMAP server settings (for reading incoming email):
#   Yahoo:      imap.mail.yahoo.com  port 993
#   iCloud:     imap.mail.me.com     port 993
#   Zoho:       imap.zoho.com        port 993
#   Fastmail:   imap.fastmail.com    port 993
#   ProtonMail: 127.0.0.1            port 1143 (Bridge required)
IMAP_HOST=
IMAP_PORT=993
#
# SMTP server settings (for sending/drafting replies):
#   Yahoo:      smtp.mail.yahoo.com  port 587
#   iCloud:     smtp.mail.me.com     port 587
#   Zoho:       smtp.zoho.com        port 587
#   Fastmail:   smtp.fastmail.com    port 587
#   ProtonMail: 127.0.0.1            port 1025 (Bridge required)
SMTP_HOST=
SMTP_PORT=587


# ---- Reply Mode -----------------------------------------------
# What to do with generated replies:
#   draft = save to Drafts folder (STRONGLY RECOMMENDED -- start here)
#   send  = auto-send immediately (only after reviewing drafts for days/weeks)
REPLY_MODE=draft


# ---- Polling Interval -----------------------------------------
# How often to check for new emails (in seconds)
# 60 = check every minute
POLL_INTERVAL_SECONDS=60


# ---- Email Filter Mode ----------------------------------------
# Controls WHICH emails the agent responds to.
#
#   whitelist = ONLY reply to emails from senders in ONLY_REPLY_TO
#               Most safe. Best when starting out or using auto-send.
#
#   blocklist = Reply to ALL emails EXCEPT those matching IGNORE_SENDERS
#               Good for customer-facing or public inboxes.
#
#   all       = Reply to every email. Not recommended.
EMAIL_FILTER_MODE=whitelist


# ---- Whitelist ------------------------------------------------
# Used when EMAIL_FILTER_MODE=whitelist
# Comma-separated list of email addresses the agent WILL reply to.
# Everyone else is ignored.
# Example: boss@company.com,teammate@company.com,support@vendor.com
ONLY_REPLY_TO=


# ---- Blocklist ------------------------------------------------
# Used when EMAIL_FILTER_MODE=blocklist
# Comma-separated list of senders or domains to SKIP.
# The agent will not reply to any email from these addresses.
# Example: noreply@newsletter.com,spam@,marketing@
IGNORE_SENDERS=noreply@,newsletter@,no-reply@,donotreply@,mailer-daemon@


# ---- Agent Persona --------------------------------------------
# How the agent introduces itself in Claude's system prompt.
# Change this to match your name, role, and communication style.
AGENT_NAME=Email Assistant
AGENT_PERSONA=You are a helpful email assistant. Reply professionally and concisely.


# ---- Deployment Mode ------------------------------------------
# local  = run manually on your computer
# server = run continuously as a background service
DEPLOY_MODE=local
