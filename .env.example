# Claude Email Agent — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The setup wizard (bash setup.sh) fills this in automatically.
# NEVER commit .env to git — it contains your private API keys.


# ─── Required ─────────────────────────────────────────────────────────────────

# Your Anthropic API key (from https://console.anthropic.com)
# Starts with: sk-ant-
ANTHROPIC_API_KEY=sk-ant-your-key-here


# ─── Deployment ───────────────────────────────────────────────────────────────

# Where the agent runs:
#   local  = on your computer (run manually)
#   server = always-on server (systemd or Docker)
DEPLOY_MODE=local


# ─── Reply Mode ───────────────────────────────────────────────────────────────

# What to do with generated replies:
#   draft = save to Gmail Drafts (STRONGLY RECOMMENDED — start here)
#   send  = auto-send immediately (only after reviewing drafts for days/weeks)
REPLY_MODE=draft


# ─── Polling Interval ─────────────────────────────────────────────────────────

# How often to check for new emails (in seconds)
# 60 = check every minute
POLL_INTERVAL_SECONDS=60


# ─── Email Filter Mode ────────────────────────────────────────────────────────

# Controls WHICH emails the agent responds to.
#
#   whitelist = ONLY reply to emails from senders in ONLY_REPLY_TO
#               Most safe. Best when starting out or using auto-send.
#
#   blocklist = Reply to ALL emails EXCEPT those matching IGNORE_SENDERS
#               Good for customer-facing or public inboxes.
#
#   all       = Reply to every email. Not recommended.
EMAIL_FILTER_MODE=whitelist


# ─── Whitelist ────────────────────────────────────────────────────────────────
# Used when EMAIL_FILTER_MODE=whitelist
#
# List of email addresses (or partial matches) you want the agent to respond to.
# Comma-separated. Can be full addresses or domain fragments.
#
# Examples:
#   ONLY_REPLY_TO=alice@company.com,bob@company.com
#   ONLY_REPLY_TO=@myteam.com,specific-person@example.com
#
# Leave empty to reply to nobody (useful as a safe default).
ONLY_REPLY_TO=


# ─── Blocklist ────────────────────────────────────────────────────────────────
# Used when EMAIL_FILTER_MODE=blocklist or all
#
# Emails from senders matching any of these patterns will NEVER get a reply.
# These are substring matches — if the pattern appears anywhere in the From address,
# the email is skipped.
IGNORE_SENDERS=noreply@,no-reply@,mailer-daemon@,postmaster@,donotreply@


# ─── Gmail Label ──────────────────────────────────────────────────────────────

# Gmail label applied to emails after the agent processes them.
# Makes it easy to see which emails have been handled.
# Leave empty to skip labeling.
LABEL_AFTER_REPLY=AI-Replied


# ─── Claude Model ─────────────────────────────────────────────────────────────

# AI model used to generate replies.
# claude-haiku-4-5 is fast and cheap (~$4-5/month at 100 emails/day).
# You do not need to change this.
MODEL=claude-haiku-4-5
MAX_TOKENS=1024
